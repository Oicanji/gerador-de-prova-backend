PORT=3000
ADMIN_PASSWORD=altere-esta-senha
SESSION_SECRET=altere-este-secret-longo-aleatorio
WORK_DIR=./data/work
API_KEYS_FILE=./data/api-keys.json
MAX_QUANTIDADE=30
JOB_TTL_MS=3600000
CORS_ORIGIN=

# Render (Web Service, Language: Docker)
# - Root Directory: ferramentas/gerador-de-prova-backend (se o repo for a raiz aulas/)
# - Dockerfile path: Dockerfile
# - Health Check Path: /health
# - Variaveis obrigatorias no painel: ADMIN_PASSWORD, SESSION_SECRET
# - PORT e definida pelo Render automaticamente
# - Chaves API: data/api-keys.json (crie em /admin apos o deploy)
# - Sem disco persistente, novas chaves somem ao redeploy; use disco Render em /app/data se precisar

# Git (repositorio separado do monorepo aulas)
# 1. Crie https://github.com/Oicanji/gerador-de-prova-backend (vazio)
# 2. git remote add origin https://github.com/Oicanji/gerador-de-prova-backend.git
# 3. git push -u origin main
# 4. No repo aulas: git submodule add https://github.com/Oicanji/gerador-de-prova-backend.git ferramentas/gerador-de-prova-backend
#    (se a pasta ja existir com .git, apague-a antes ou use git submodule absorbgitdirs)
